<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} &mdash; MMM</title>
    <link rel="stylesheet" href="{{ PATH_PREFIX }}assets/style.css">
    <link rel="preload" as="image" href="{{ PATH_PREFIX }}assets/images/mountain_banner.webp" type="image/webp" fetchpriority="high">
</head>
<body>
    {% set show_toc = false if toc is none else toc %}
    {% include 'navbar.tmpl' %}

    <div class="banner">
        <h1>{{ title }}</h1>
    </div>

    <div class="page-layout">
         {% if show_toc == true %}
         <aside class="page-sidebar">
             <div class="toc-toggle" id="toc-toggle">&#9776; Contents</div>

             <nav class="toc-nav" id="toc-nav">
                 {{ toc_html }}
             </nav>
         </aside>
         {% endif %}
	 
         <main class="page-content">
             {{ content }}
         </main>
    </div>

    {% include 'footer.tmpl' %}
</body>
</html>
