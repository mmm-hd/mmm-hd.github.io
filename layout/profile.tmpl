<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default(name) }} &mdash; MMM</title>
    <link rel="stylesheet" href="{{ PATH_PREFIX }}assets/style.css">
</head>
<body>
    {% include 'navbar.tmpl' %}

    <div class="profile-layout">
         <aside class="profile-sidebar">
             <img src="{{ PATH_PREFIX }}{{ photo | default('assets/images/placeholder.jpeg') }}"
                  alt="{{ title | default('placeholder') }}" class="profile-photo">

             <h1 class="sidebar-name">{{ name }}</h1>

             {% if role %}
             <p class="sidebar-role">{{ role }}</p>
             {% endif %}

             {% if toc == true %}
             <div class="toc-toggle" id="toc-toggle">&#9776; Contents</div>

             <nav class="toc-nav" id="toc-nav">
                 {{ toc_html }}
             </nav>
             {% endif %}
         </aside>

         <main class="profile-content">
             {{ content }}
         </main>
     </div>

    {% include 'footer.tmpl' %}
</body>
</html>