<div class="teaching-block">
    <h3 class="course-heading">{{ course_title }}</h3>
    <table class="schedule-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Time</th>
                <th>Location</th>
            </tr>
        </thead>
        <tbody>
            {% for entry in schedule %}
            <tr>
                <td>{{ entry.date }}</td>
                <td>{{ entry.time }}</td>
                <td>{{ entry.room }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>